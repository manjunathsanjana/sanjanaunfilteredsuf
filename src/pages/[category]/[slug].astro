---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post: CollectionEntry<'blog'>) => ({
		params: { category: post.data.category, slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Sanjana Unfiltered`}>
	<header class="page-hero">
		<div class="container">
			<h1 class="page-hero__title">{post.data.title}</h1>
			<p class="page-hero__desc">{post.data.date}</p>
		</div>
	</header>

	<main class="posts-list-section">
		<div class="container">
			<a href={`/${post.data.category}`} class="back-link-float reveal" aria-label="Back to category">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
			</a>

			<article class="post-content-body reveal visible">
				<Content />
			</article>
		</div>
	</main>
</Layout>

<style is:global>
	body {
		background-image: linear-gradient(rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.4)), url('/images/hero-collage.jpg') !important;
		background-size: 800px auto !important;
		background-repeat: repeat !important;
	}

	main {
		flex: 1;
	}

	.back-link-float {
		position: fixed;
		top: 6rem;
		left: 2rem;
		width: 46px;
		height: 46px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(250, 245, 240, 0.7);
		backdrop-filter: blur(16px) saturate(1.8);
		-webkit-backdrop-filter: blur(16px) saturate(1.8);
		border: 1px solid rgba(232, 196, 176, 0.3);
		border-radius: 50%;
		color: var(--color-accent);
		text-decoration: none;
		z-index: 1000;
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
	}

	.back-link-float:hover {
		background: var(--color-accent);
		color: white;
		transform: scale(1.1) rotate(-8deg);
		box-shadow: 0 12px 48px rgba(232, 196, 176, 0.4);
		border-color: transparent;
	}

	@media (max-width: 900px) {
		.back-link-float {
			top: auto;
			bottom: 2rem;
			left: 2rem;
			width: 40px;
			height: 40px;
		}
	}

	.post-content-body {
		max-width: 800px;
		margin: 2.5rem auto;
		background: rgba(250,245,240,0.85);
		backdrop-filter: blur(8px);
		padding: clamp(2rem, 5vw, 4rem);
		border-radius: var(--radius-md);
		border: 1px solid rgba(232,196,176,0.2);
		box-shadow: var(--shadow-soft);
		line-height: 1.8;
		font-size: 1.05rem;
		color: var(--color-text);
	}

	.post-content-body h1, 
	.post-content-body h2, 
	.post-content-body h3 {
		margin: 2rem 0 1rem;
		color: var(--color-accent);
		line-height: 1.2;
	}

	.post-content-body p {
		margin-bottom: 1.5rem;
	}

	.post-content-body img {
		border-radius: var(--radius-md);
		margin: 2.5rem 0;
		box-shadow: var(--shadow-elevated);
		width: 100%;
		height: auto;
		display: block;
		image-rendering: high-quality;
	}

	/* Mango Gallery Grid */
	.mango-gallery {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
		margin: 3rem 0;
	}

	.mango-gallery__item {
		position: relative;
		border-radius: var(--radius-md);
		overflow: hidden;
		box-shadow: var(--shadow-soft);
		aspect-ratio: 1 / 1;
		transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
	}

	.mango-gallery__item:hover {
		transform: scale(1.05) translateY(-4px);
		box-shadow: var(--shadow-elevated);
		z-index: 10;
	}

	.mango-gallery__item img {
		width: 100% !important;
		height: 100% !important;
		object-fit: cover !important;
		margin: 0 !important;
		border-radius: 0 !important;
		box-shadow: none !important;
		transition: transform 0.6s ease;
	}

	.mango-gallery__item:hover img {
		transform: scale(1.08);
	}

	@media (max-width: 768px) {
		.mango-gallery {
			grid-template-columns: repeat(2, 1fr);
			gap: 1rem;
		}
	}

	@media (max-width: 480px) {
		.mango-gallery {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
	}
</style>
